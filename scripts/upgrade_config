#!/bin/bash

BINDIR=$(cd $(dirname $0) && pwd)

. ${BINDIR}/common

# Unified upgrade logging -> logs/fpp_system_upgrades.log. Usually reached as a nested
# step of git_pull / git_branch / upgrade_FPP, whose tee is already installed; the
# FPP_OPLOG_ACTIVE guard in startOpLog keeps this from stacking a second one.
# -notee (passed by SD/FPP_Install.sh at install time, when there is no parent op
# and the media/logs tree may not exist yet) still opts out of logging entirely.
if [ "$1" != "-notee" ]; then
    startUpgradeLog "fpp-config-upgrade" "${FPPVERSION}"
fi

echo "Checking config version"
export FPPVERSION

########################################################################

if [ -f ${CFGVERSIONFILE} ]; then
	CFGVERSION=$(cat ${CFGVERSIONFILE})
else
    CFGVERSION="99999"
fi

echo "FPP Version: ${FPPVERSION}"
echo "Config Version: ${CFGVERSION}"

for VERSION in $(seq 1 1000)
do
	if [ ${VERSION} -gt ${CFGVERSION} ]
	then
		if [ -f "${UPGRADEDIR}/${VERSION}/upgrade.sh" ]
		then
			echo "Upgrading config to version ${VERSION}"
			(cd ${UPGRADEDIR}/${VERSION} && ./upgrade.sh)
			if [ $? -eq 0 ]
			then
                CFGVERSION=${VERSION}
                echo ${VERSION} > ${CFGVERSIONFILE}
                echo ">>SUCCESS upgraded to config version ${VERSION}"
			else
                echo ">>FAILED to update to config version ${VERSION}"
                echo "!!Config Version not up to date!!"
                exit 0
			fi
		else
			echo "Up to date at config version ${CFGVERSION}"
			exit 0
		fi
	fi
done

