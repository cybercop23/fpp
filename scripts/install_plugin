#!/bin/bash

BINDIR=$(cd $(dirname $0) && pwd)

. ${BINDIR}/common
. ${BINDIR}/functions

if [ "x$1" = "x" ] || [ "x$2" = "x" ] || [ "x$3" = "x" ]
then
	echo "USAGE: $0 PLUGINNAME GITURL BRANCH SHA1"
	exit 1
fi

teeOutput

# Sanitize the URL for display/logging in case it contains embedded GitHub
# credentials (https://user:token@host/...). The original $2 is still passed
# to git clone unmodified so authentication still works.
SAFE_URL=$(echo "$2" | sed -E 's#(https?://)[^/@[:space:]]+@#\1#')

echo "Installing plugin $1"
cd ${PLUGINDIR} && $SUDO git clone --single-branch --branch $3 $2 $1
rc=$?
if [ $rc -ne 0 ]; then
    echo "======================================================================================="
	echo "Failed to fetch $1 using $SAFE_URL -- aborting"
    echo ""
    echo "The most common reason plugin installs fail is the lack of functioning Internet Access"
    echo ""
    echo "You can troubleshoot this by going to the 'Help' menu and selecting 'System Heath Check'" 
    echo "======================================================================================="
	exit 1
fi

if [ "x$4" != "x" ]
then
    (cd $1 && $SUDO git reset --hard $4)
fi


if [ "${FPPPLATFORM}" != "MacOS" ]; then
    $SUDO chown -R fpp:fpp $1
fi

# When FPP_SKIP_INSTALL_SCRIPT=1 the caller (the Plugin Manager) wants to
# resolve the plugin's declared dependencies before its own install script
# runs, so it clones here and runs the plugin's fpp_install.sh itself
# afterwards. Otherwise run the install script inline as before.
if [ "x${FPP_SKIP_INSTALL_SCRIPT}" = "x1" ]; then
    echo "Skipping fpp_install.sh for $1 (dependencies will be resolved, then it runs)"
elif [ -x "${PLUGINDIR}/$1/scripts/fpp_install.sh" ]
then
    echo "Running fpp_install.sh script for $1"
    $SUDO ${PLUGINDIR}/$1/scripts/fpp_install.sh FPPDIR=${FPPDIR} SRCDIR=${FPPDIR}/src
else
    if [ -x "${PLUGINDIR}/$1/fpp_install.sh" ]; then
        echo "Running fpp_install.sh script for $1"
        $SUDO ${PLUGINDIR}/$1/fpp_install.sh FPPDIR=${FPPDIR} SRCDIR=${FPPDIR}/src
    fi
fi
